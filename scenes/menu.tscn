[sub_resource type="GDScript" id="GDScript_mhnvy"]
script/source = "extends Label
var played : bool = false;

@export var firstLevel : PackedScene;

var blinkTimer : float = 0.0;

func _process(delta: float) -> void:
	if Input.is_action_just_pressed(\"jump\"):
		_start_play();
	if played:
		blinkTimer += delta;
		if blinkTimer > 0.2:
			blinkTimer = 0.0;
			visible = !visible;

func _start_play() -> void:
	if played: return;
	played = true;
	$Lixi.play();
	await get_tree().create_timer(2).timeout;
	Transition.change_scene_to_packed(firstLevel);
	pass;
"

